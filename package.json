{
  "name": "ridehub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "ios": "pnpm build && npx cap sync && npx cap open ios",
    "android": "pnpm build && npx cap sync && npx cap open android",
    "sync": "npx cap sync",
    "serve": "vite --host",
